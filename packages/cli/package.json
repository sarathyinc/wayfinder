{
  "name": "@wayfinder/cli",
  "version": "0.0.0",
  "type": "module",
  "bin": {
    "assist": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "dev:assist": "tsx src/index.ts"
  },
  "dependencies": {
    "@wayfinder/core": "workspace:*",
    "@wayfinder/providers": "workspace:*",
    "cac": "^6.7.14"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "vitest": "^2.1.0"
  }
}