{
  "name": "@wayfinder/adapter-nextjs",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react/AssistWidget.d.ts",
      "import": "./dist/react/AssistWidget.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "next": "^14 || ^15"
  },
  "dependencies": {
    "@wayfinder/core": "workspace:*",
    "@wayfinder/widget": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.12",
    "react": "^18.3.1",
    "tsup": "^8.3.0",
    "vitest": "^2.1.0"
  }
}