{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "version": {
      "type": "number",
      "const": 2
    },
    "defaultLocale": {
      "default": "en",
      "type": "string",
      "minLength": 1
    },
    "pages": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "routeKey": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "object",
                "propertyNames": {
                  "type": "string"
                },
                "additionalProperties": {
                  "type": "string"
                }
              }
            ]
          },
          "personas": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "description": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "object",
                "propertyNames": {
                  "type": "string"
                },
                "additionalProperties": {
                  "type": "string"
                }
              }
            ]
          },
          "available": {
            "default": true,
            "type": "boolean"
          }
        },
        "required": [
          "routeKey",
          "title",
          "personas",
          "available"
        ],
        "additionalProperties": false
      }
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "route": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "object",
                "propertyNames": {
                  "type": "string"
                },
                "additionalProperties": {
                  "type": "string"
                }
              }
            ]
          },
          "personas": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "effect": {
            "type": "string",
            "enum": [
              "navigate",
              "open",
              "write"
            ]
          },
          "params": {
            "default": [],
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string",
                  "minLength": 1
                },
                "type": {
                  "type": "string",
                  "minLength": 1
                },
                "required": {
                  "type": "boolean"
                },
                "source": {
                  "type": "string",
                  "enum": [
                    "form",
                    "query",
                    "path"
                  ]
                }
              },
              "required": [
                "name",
                "type",
                "required",
                "source"
              ],
              "additionalProperties": false
            }
          },
          "synonyms": {
            "default": [],
            "type": "array",
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "object",
                  "propertyNames": {
                    "type": "string"
                  },
                  "additionalProperties": {
                    "type": "string"
                  }
                }
              ]
            }
          },
          "steps": {
            "default": [],
            "type": "array",
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "object",
                  "propertyNames": {
                    "type": "string"
                  },
                  "additionalProperties": {
                    "type": "string"
                  }
                }
              ]
            }
          },
          "spotlight": {
            "default": [],
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "execution": {
            "default": null,
            "anyOf": [
              {
                "type": "object",
                "properties": {
                  "navigate": {
                    "type": "string",
                    "minLength": 1
                  },
                  "open": {
                    "type": "string",
                    "minLength": 1
                  },
                  "tier": {
                    "type": "string",
                    "enum": [
                      "guidance",
                      "command-bus",
                      "url-state"
                    ]
                  }
                },
                "required": [
                  "navigate",
                  "tier"
                ],
                "additionalProperties": false
              },
              {
                "type": "null"
              }
            ]
          }
        },
        "required": [
          "id",
          "route",
          "label",
          "personas",
          "effect",
          "params",
          "synonyms",
          "steps",
          "spotlight",
          "execution"
        ],
        "additionalProperties": false
      }
    },
    "fields": {
      "default": [],
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "label": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "object",
                "propertyNames": {
                  "type": "string"
                },
                "additionalProperties": {
                  "type": "string"
                }
              }
            ]
          },
          "page": {
            "type": "string",
            "minLength": 1
          },
          "tab": {
            "default": null,
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "personas": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "synonyms": {
            "default": [],
            "type": "array",
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "object",
                  "propertyNames": {
                    "type": "string"
                  },
                  "additionalProperties": {
                    "type": "string"
                  }
                }
              ]
            }
          }
        },
        "required": [
          "label",
          "page",
          "tab",
          "personas",
          "synonyms"
        ],
        "additionalProperties": false
      }
    },
    "transitions": {
      "default": [],
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "from": {
            "type": "string",
            "minLength": 1
          },
          "to": {
            "type": "string",
            "minLength": 1
          },
          "via": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "from",
          "to",
          "via"
        ],
        "additionalProperties": false
      }
    },
    "tasks": {
      "default": [],
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "object",
                "propertyNames": {
                  "type": "string"
                },
                "additionalProperties": {
                  "type": "string"
                }
              }
            ]
          },
          "personas": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "goal": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "object",
                "propertyNames": {
                  "type": "string"
                },
                "additionalProperties": {
                  "type": "string"
                }
              }
            ]
          },
          "sequence": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "source": {
            "type": "string",
            "enum": [
              "suggested",
              "annotated"
            ]
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        },
        "required": [
          "id",
          "title",
          "personas",
          "sequence",
          "source"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "version",
    "defaultLocale",
    "pages",
    "actions",
    "fields",
    "transitions",
    "tasks"
  ],
  "additionalProperties": false
}
